# Application
APP_NAME=multi_agent_rag_retail
APP_ENV=development
LOG_LEVEL=INFO

# Alibaba DashScope (sole LLM provider; OpenAI SDK is used as HTTP transport
# via the OpenAI-compatible endpoint below)
ALIBABA_API_KEY=
ALIBABA_URL=https://ws-v9y2oinbtzzm4ey9.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
ALIBABA_LLM_MODEL=qwen-mt-flash
ALIBABA_LLM_BACKUP=qwen3.5-flash
# DashScope has a separate, non-OpenAI-compatible endpoint for rerank.
ALIBABA_RERANK_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# Embedding (RAG)
# Alibaba is the sole embedding provider. text-embedding-v3 (1024-dim) via
# the OpenAI-compatible API. If the call fails, the retriever falls back to
# a deterministic hash-based vector (offline dev only).
EMBEDDING_PROVIDER=alibaba
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# Rerank (RAG)
# Primary: Alibaba gte-rerank
# Fallback: "none" → skip rerank, sort by hybrid score
RERANK_PROVIDER=alibaba
RERANK_MODEL=gte-rerank
RERANK_TOP_N=20

# Hybrid retrieval weights
HYBRID_SPARSE_WEIGHT=0.4
HYBRID_DENSE_WEIGHT=0.6
HYBRID_TOP_N=20
RERANK_FINAL_K=5

# PostgreSQL (app data + LangGraph checkpointer)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_password
POSTGRES_DB=retail_db
DATABASE_URL=postgresql+psycopg2://retail:retail_password@postgres:5432/retail_db

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=policy_docs

# Langfuse (LLM observability, required)
# These must match the credentials you set when first running langfuse
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_NEXTAUTH_SECRET=please-change-me-in-prod
LANGFUSE_USER_EMAIL=admin@example.com
LANGFUSE_USER_PASSWORD=please-change-me-in-prod

# Guardrails
ENABLE_INPUT_GUARDRAIL=true
ENABLE_OUTPUT_GUARDRAIL=true
ENABLE_PII_REDACTION=true

# Chunking
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# LangGraph checkpointer
# "memory" for local dev/tests (no Postgres required)
# "postgres" for production (uses DATABASE_URL)
CHECKPOINT_BACKEND=memory
CHECKPOINT_TTL_DAYS=30
